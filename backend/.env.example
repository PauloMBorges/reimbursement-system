# Banco de dados
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reimbursement_db?schema=public"

# Servidor
PORT=3333
NODE_ENV=development

# JWT
JWT_SECRET="troque-este-valor-por-uma-string-longa-e-aleatoria-em-producao"
JWT_EXPIRES_IN="1d"

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# NTFY
NTFY_TOPIC=seu-topico-aqui
