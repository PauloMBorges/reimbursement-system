  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Verifica que o login deu certo\r",
                  "pm.test('Login bem-sucedido (status 200)', function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Salva o token no environment automaticamente\r",
                  "if (pm.response.code === 200) {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.environment.set('token', data.token);\r",
                  "    console.log('✅ Token salvo no environment');\r",
                  "}\r",
                  "\r",
                  "// Valida estrutura da resposta\r",
                  "pm.test('Resposta contém token e usuario', function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.expect(data).to.have.property('token');\r",
                  "    pm.expect(data).to.have.property('usuario');\r",
                  "    pm.expect(data.usuario).to.not.have.property('senha');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"email\": \"admin@pitang.com\",\r\n    \"senha\": \"senha123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
